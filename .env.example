# Copy to .env.local and fill in real values.

# Required for Google sign-in.
APP_BASE_URL=http://127.0.0.1:3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional. Comma-separated emails. Leave blank for open Google sign-up.
GOOGLE_ALLOWED_EMAILS=

# Required for signed login sessions.
SESSION_SECRET=replace-with-a-long-random-string
HOST=127.0.0.1
PORT=3000

# Internal owner dashboard at /dev.
DEV_DASHBOARD_PASSWORD=

# How long Google Place Details stay cached before refresh.
PLACE_CACHE_TTL_DAYS=30
GEOCODE_CACHE_TTL_DAYS=30
SEARCH_CACHE_TTL_DAYS=7
WEBSITE_SCAN_CACHE_TTL_DAYS=14

# Free credits granted to a new Google user until payments are connected.
DEFAULT_USER_CREDITS=500

# Comma-separated owner emails with unlimited internal access and no unlock charges.
OWNER_EMAILS=

# Google Sheets V1 storage.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional alternative: paste the service account JSON instead of separate email/private key.
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Recommended hosted storage on Vercel. Run supabase/schema.sql in Supabase first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Places API is required for lead discovery quality.
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# Optional dashboard map picker. Use a browser-restricted key with Maps JavaScript API enabled.
GOOGLE_MAPS_BROWSER_KEY=

# Legacy optional search providers are not used by the strict Places discovery flow.
SERPAPI_KEY=
BING_SEARCH_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Keep disabled for strict lead quality.
PUBLIC_SEARCH_FALLBACK=false

# Local fallback for development only. V1 production storage should be Google Sheets.
LOCAL_DEV_STORAGE=false
